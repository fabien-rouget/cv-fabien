---
interface NavItem {
  href: string;
  label: string;
}

interface Props {
  items: NavItem[];
}

const { items } = Astro.props;
---

<nav class="page-nav" aria-label="Navigation des sections">
  <ul class="page-nav-list">
    {items.map((item) => (
      <li>
        <a class="page-nav-link" href={item.href}>
          {item.label}
        </a>
      </li>
    ))}
  </ul>
</nav>
