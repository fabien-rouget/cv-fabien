---
import type { Experience } from "../data/experience";
import TagList from "./TagList.astro";

interface Props {
  experience: Experience;
}

const { experience } = Astro.props;
const compactPeriod = experience.period
  .replace(/^d['’]/i, "")
  .replace(/^de\s+/i, "")
  .replace(/\s+à\s+/i, " → ");
---

<article class="experience-card">
  <div class="experience-marker" aria-hidden="true">
    <span class="experience-dot"></span>
  </div>

  <div class="experience-main">
    <header class="experience-header">
      <div class="experience-heading">
        <h3>{experience.role}</h3>
        <p class="experience-meta">
          <span class="experience-company">{experience.company}</span>
          <span class="experience-location"> — {experience.location}</span>
          <span class="experience-period"> · {compactPeriod}</span>
        </p>
        <p class="experience-kicker">{experience.context}</p>
      </div>
    </header>

    <ul class="experience-impact-list">
      {experience.impacts.map((impact) => <li>{impact}</li>)}
    </ul>

    {experience.stack.length > 0 && (
      <div class="experience-support">
        <TagList items={experience.stack} />
      </div>
    )}
  </div>
</article>
